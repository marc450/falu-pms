@page "/downloads"
@using System.IO
@inject NavigationManager Navigation
@inject AuthenticationService AuthService

<AuthorizeView RequiredRole="UserRole.Supervisor">
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mt-3 mb-4">
        <h2 class="text-white">Logfiles</h2>
        <span class="badge bg-success">CSV Export</span>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible">
            <i class="bi bi-check-circle-fill me-2"></i> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }

    <div class="row">
        <!-- All Machines Log -->
        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary shadow" style="height: 500px;">
                <div class="card-header bg-primary d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">All Machines Log</h4>
                    @if (AllMachinesLogExists())
                    {
                        <button class="btn btn-sm btn-danger" @onclick='() => ConfirmDelete("wwwroot/logs/AllMachines.csv", "AllMachines.csv")'>
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    }
                </div>
                <div class="card-body d-flex flex-column">
                    @if (AllMachinesLogExists())
                    {
                        <p class="text-muted small mb-2">
                            Size: @GetFileSize("wwwroot/logs/AllMachines.csv") &nbsp;|&nbsp;
                            Last modified: @GetLastModified("wwwroot/logs/AllMachines.csv")
                        </p>
                        <div class="flex-fill overflow-auto mb-2">
                            <table class="table table-dark table-sm table-bordered mb-0" style="font-size: 0.75rem;">
                                <thead class="text-warning">
                                    @{var allHeaders = GetCsvHeaders("wwwroot/logs/AllMachines.csv");}
                                    <tr>
                                        @foreach (var h in allHeaders)
                                        {
                                            <th>@h</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in GetCsvRows("wwwroot/logs/AllMachines.csv"))
                                    {
                                        <tr>
                                            @foreach (var cell in row)
                                            {
                                                <td>@cell</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <a href="/logs/AllMachines.csv" download="@($"AllMachines_{DateTime.Now:yyyyMMdd}.csv")" class="btn btn-success w-100 mt-auto">
                            <i class="bi bi-download"></i> Download CSV
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-auto mb-0">
                            <i class="bi bi-exclamation-triangle"></i> No log file available yet.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Individual Machine Logs -->
        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary shadow" style="height: 500px;">
                <div class="card-header bg-primary">
                    <h4 class="mb-0">Individual Machine Logs</h4>
                </div>
                <div class="card-body d-flex flex-column">
                    @if (GetMachineLogFiles().Any())
                    {
                        <div class="machine-log-list flex-fill">
                            @foreach (var file in GetMachineLogFiles())
                            {
                                var fileName = Path.GetFileName(file);
                                var machineName = Path.GetFileNameWithoutExtension(file);
                                var isExpanded = expandedFile == file;
                                <div class="mb-2 border border-secondary rounded overflow-hidden">
                                    <div class="d-flex justify-content-between align-items-center p-2 bg-secondary">
                                        <button class="btn btn-sm btn-link text-white text-decoration-none p-0 fw-bold" @onclick="() => ToggleFile(file)">
                                            <i class="bi bi-@(isExpanded ? "chevron-down" : "chevron-right") me-1"></i>
                                            @machineName
                                        </button>
                                        <div class="d-flex gap-1 align-items-center">
                                            <small class="text-muted me-2">@GetFileSize(file)</small>
                                            <a href="/logs/machines/@fileName" download="@($"{machineName}_{DateTime.Now:yyyyMMdd}.csv")" class="btn btn-sm btn-success">
                                                <i class="bi bi-download"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(file, fileName)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                    @if (isExpanded)
                                    {
                                        <div class="p-1" style="max-height: 200px; overflow: auto;">
                                            <table class="table table-dark table-sm table-bordered mb-0" style="font-size: 0.7rem;">
                                                <thead class="text-warning">
                                                    <tr>
                                                        @foreach (var h in GetCsvHeaders(file))
                                                        {
                                                            <th>@h</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in GetCsvRows(file))
                                                    {
                                                        <tr>
                                                            @foreach (var cell in row)
                                                            {
                                                                <td>@cell</td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle"></i> No machine log files available yet.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirm)
{
    <div class="modal-backdrop-dark" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1050;">
        <div class="modal d-block" style="z-index: 1055;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-white border-danger">
                    <div class="modal-header bg-danger">
                        <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Delete Logfile</h5>
                    </div>
                    <div class="modal-body">
                        Are you sure you want to permanently delete <strong>@deleteFileName</strong>?
                        <br /><small class="text-muted">This action cannot be undone.</small>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                        <button class="btn btn-danger" @onclick="ExecuteDelete">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .machine-log-list {
        overflow-y: auto;
        padding-right: 4px;
    }

    .machine-log-list::-webkit-scrollbar { width: 8px; }
    .machine-log-list::-webkit-scrollbar-track { background: #1a1a1a; border-radius: 4px; }
    .machine-log-list::-webkit-scrollbar-thumb { background: #555; border-radius: 4px; }
    .machine-log-list::-webkit-scrollbar-thumb:hover { background: #777; }
</style>

@code {
    private string? expandedFile;
    private bool showDeleteConfirm = false;
    private string deleteFilePath = "";
    private string deleteFileName = "";
    private string successMessage = "";

    private void ToggleFile(string file)
    {
        expandedFile = expandedFile == file ? null : file;
    }

    private void ConfirmDelete(string filePath, string fileName)
    {
        deleteFilePath = filePath;
        deleteFileName = fileName;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteFilePath = "";
        deleteFileName = "";
    }

    private void ExecuteDelete()
    {
        try
        {
            if (File.Exists(deleteFilePath))
            {
                File.Delete(deleteFilePath);
                successMessage = $"File '{deleteFileName}' deleted successfully.";
                if (expandedFile == deleteFilePath)
                    expandedFile = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting file: {ex.Message}");
        }
        finally
        {
            showDeleteConfirm = false;
            deleteFilePath = "";
            deleteFileName = "";
        }
    }

    private bool AllMachinesLogExists()
    {
        try { return File.Exists("wwwroot/logs/AllMachines.csv"); }
        catch { return false; }
    }

    private List<string> GetMachineLogFiles()
    {
        try
        {
            var path = "wwwroot/logs/machines/";
            if (Directory.Exists(path))
                return Directory.GetFiles(path, "*.csv").OrderBy(f => f).ToList();
        }
        catch (Exception ex) { Console.WriteLine($"Error getting log files: {ex.Message}"); }
        return new List<string>();
    }

    private List<string> GetCsvHeaders(string filePath)
    {
        try
        {
            if (!File.Exists(filePath)) return new();
            var firstLine = File.ReadLines(filePath).FirstOrDefault();
            return firstLine?.Split(';').ToList() ?? new();
        }
        catch { return new(); }
    }

    private List<List<string>> GetCsvRows(string filePath, int maxRows = 50)
    {
        try
        {
            if (!File.Exists(filePath)) return new();
            return File.ReadLines(filePath)
                .Skip(1) // skip header
                .TakeLast(maxRows)
                .Select(line => line.Split(';').ToList())
                .ToList();
        }
        catch { return new(); }
    }

    private string GetFileSize(string filePath)
    {
        try
        {
            if (File.Exists(filePath))
            {
                var size = new FileInfo(filePath).Length / 1024.0;
                return size < 1024 ? $"{size:F1} KB" : $"{size / 1024.0:F1} MB";
            }
        }
        catch { }
        return "N/A";
    }

    private string GetLastModified(string filePath)
    {
        try
        {
                    if (File.Exists(filePath))
                            return new FileInfo(filePath).LastWriteTime.ToString("yyyy-MM-dd HH:mm:ss");
                    }
                    catch { }
                    return "N/A";
                }
            }
            </AuthorizeView>