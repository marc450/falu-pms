{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr*)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf*)",
      "Bash(rm -Rf *)",
      "Bash(sudo rm*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git checkout --*)",
      "Bash(supabase db reset*)",
      "Bash(npx supabase db reset*)",
      "Bash(supabase projects delete*)",
      "Bash(npx supabase projects delete*)",
      "Bash(dropdb*)",
      "Bash(pg_dropcluster*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-destructive-bash.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
